    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Build_Doctor_Email_Body</name>
        <label>Build Doctor Email Body</label>
        <locationX>176</locationX>
        <locationY>600</locationY>
        <assignmentItems>
            <assignToReference>varDoctorEmailBody</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Dear Doctor,

A new lab result has been uploaded for your patient.

Patient     : {!varPatient.Name}
Admission   : {!varAdmission.Name}
Result      : {!$Record.Result_Summary__c}
Status      : {!$Record.Status__c}

Please review the result at your earliest convenience.

Hospital Management System</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Send_Doctor_Notification</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Build_Patient_Email_Body</name>
        <label>Build Patient Email Body</label>
        <locationX>176</locationX>
        <locationY>720</locationY>
        <assignmentItems>
            <assignToReference>varPatientEmailBody</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Dear {!varPatient.Name},

Your lab results are now available.

Result Summary : {!$Record.Result_Summary__c}
Admission      : {!varAdmission.Name}

Please contact your doctor for interpretation and next steps.

Warm regards,
Hospital Management Team</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Send_Patient_Notification</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Doctor_Email</name>
        <label>Set Doctor Email from Staff</label>
        <locationX>176</locationX>
        <locationY>480</locationY>
        <assignmentItems>
            <assignToReference>varDoctorEmail</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>varDoctorStaff.Email__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Doctor_Email_Exists</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Check_Admission_Exists</name>
        <label>Admission Linked?</label>
        <locationX>176</locationX>
        <locationY>120</locationY>
        <defaultConnectorLabel>No Admission — End</defaultConnectorLabel>
        <rules>
            <name>Admission_Present</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Admission__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Admission_Record</targetReference>
            </connector>
            <label>Admission Present</label>
        </rules>
    </decisions>
    <decisions>
        <name>Doctor_Email_Exists</name>
        <label>Doctor Email Exists?</label>
        <locationX>176</locationX>
        <locationY>600</locationY>
        <defaultConnector>
            <targetReference>Patient_Email_Exists</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Doctor Email — Skip</defaultConnectorLabel>
        <rules>
            <name>Has_Doctor_Email</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varDoctorEmail</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Build_Doctor_Email_Body</targetReference>
            </connector>
            <label>Doctor Email Available</label>
        </rules>
    </decisions>
    <decisions>
        <name>Patient_Email_Exists</name>
        <label>Patient Email Exists?</label>
        <locationX>176</locationX>
        <locationY>720</locationY>
        <defaultConnector>
            <targetReference>Update_Admission_Status</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Patient Email — Skip</defaultConnectorLabel>
        <rules>
            <name>Has_Patient_Email</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varPatient.Email__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Build_Patient_Email_Body</targetReference>
            </connector>
            <label>Patient Email Available</label>
        </rules>
    </decisions>
    <description>After Create flow on Lab_Result__c. When a lab result is uploaded: fetches the related Admission, Doctor, and Patient; sends notification emails to both Doctor and Patient; and updates the Admission Status to Lab Results Available.</description>
    <interviewLabel>Lab Result Notification {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Lab Result Notification</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
