<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <customErrors>
        <name>Error_Outstanding_Bill</name>
        <label>Outstanding Bill Error</label>
        <locationX>176</locationX>
        <locationY>240</locationY>
        <customErrorMessages>
            <errorMessage>Outstanding bill exists. Discharge not allowed.</errorMessage>
            <isFieldError>false</isFieldError>
        </customErrorMessages>
    </customErrors>
    <decisions>
        <name>Check_Outstanding_Balance</name>
        <label>Outstanding Balance Exists?</label>
        <locationX>176</locationX>
        <locationY>120</locationY>
        <defaultConnectorLabel>No Outstanding Balance — Allow Discharge</defaultConnectorLabel>
        <rules>
            <name>Has_Outstanding_Balance</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Outstanding_Balance__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Error_Outstanding_Bill</targetReference>
            </connector>
            <label>Balance &gt; 0 — Block Discharge</label>
        </rules>
    </decisions>
    <description>Before Update flow on Admission__c. When Status__c changes to Discharged, checks if Outstanding_Balance__c is greater than 0. If an outstanding bill exists, a record-level error is thrown to prevent discharge.</description>
    <interviewLabel>Discharge Bill Validation {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Discharge Bill Validation</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>176</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Outstanding_Balance</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Discharged</stringValue>
            </value>
        </filters>
        <object>Admission__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
