<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Admission_Date_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>Admission_Date_Time__c &lt; (NOW() - 1)</errorConditionFormula>
    <errorDisplayField>Admission_Date_Time__c</errorDisplayField>
    <errorMessage>Admission can&apos;t be in the past.</errorMessage>
</ValidationRule>
