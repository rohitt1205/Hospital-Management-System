<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Organ_Type_for_Organ</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Purpose__c, &quot;Organ&quot;), ISBLANK(Organ_Type__c))</errorConditionFormula>
    <errorDisplayField>Organ_Type__c</errorDisplayField>
    <errorMessage>Organ Type is required when the donation purpose is Organ.</errorMessage>
</ValidationRule>
