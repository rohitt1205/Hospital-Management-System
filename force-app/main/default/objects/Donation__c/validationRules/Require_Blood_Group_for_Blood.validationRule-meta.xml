<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Blood_Group_for_Blood</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISPICKVAL(Purpose__c, &quot;Blood&quot;), ISBLANK(TEXT(Blood_Group__c)))</errorConditionFormula>
    <errorDisplayField>Blood_Group__c</errorDisplayField>
    <errorMessage>Blood Group is required when the donation purpose is Blood.</errorMessage>
</ValidationRule>
