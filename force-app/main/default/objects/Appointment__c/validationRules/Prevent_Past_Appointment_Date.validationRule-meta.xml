<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_Past_Appointment_Date</fullName>
    <active>true</active>
    <errorConditionFormula>AND(OR(ISNEW(), ISCHANGED(Appointment_Date__c)), Appointment_Date__c &lt; TODAY())</errorConditionFormula>
    <errorDisplayField>Appointment_Date__c</errorDisplayField>
    <errorMessage>Appointment date cannot be in the past.
Please select today or a future date.</errorMessage>
</ValidationRule>
