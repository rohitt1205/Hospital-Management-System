<aura:component implements="lightning:appHomeTemplate" description="HMS Custom 60/40 Header and Two Column Layout Template" access="global">
    <aura:attribute name="header" type="Aura.Component[]" access="global" />
    <aura:attribute name="left" type="Aura.Component[]" access="global" />
    <aura:attribute name="right" type="Aura.Component[]" access="global" />

    <div class="hms-layout-container">
        <!-- Header Region -->
        <aura:if isTrue="{!not(empty(v.header))}">
            <div class="hms-layout-header slds-m-bottom_medium">
                {!v.header}
            </div>
        </aura:if>
        
        <!-- Two Column division (60% / 40%) -->
        <div class="slds-grid slds-wrap slds-gutters">
            <div class="slds-col slds-size_1-of-1 slds-medium-size_7-of-12 hms-layout-left">
                {!v.left}
            </div>
            <div class="slds-col slds-size_1-of-1 slds-medium-size_5-of-12 hms-layout-right">
                {!v.right}
            </div>
        </div>
    </div>
</aura:component>